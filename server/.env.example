# Antigravity Payment Server — Environment Variables
# Copy this file to .env and fill in your real credentials

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_YourKeyHere
RAZORPAY_KEY_SECRET=YourSecretHere
RAZORPAY_WEBHOOK_SECRET=YourWebhookSecretHere

# Razorpay Plan IDs (create these in Razorpay Dashboard → Subscriptions → Plans)
RAZORPAY_PLAN_GROWTH=plan_YourGrowthPlanId
RAZORPAY_PLAN_PRO=plan_YourProPlanId

# ── Firebase Admin ────────────────────────────────────────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_DATABASE_URL=https://antigravity-tuition-os-default-rtdb.firebaseio.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173
