rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ALL COLLECTIONS UNBLOCKING ────────────────────────────
    // This allows public reading and authenticated writing for EVERY collection.
    // This is the "Master Unblock" to fix all permission errors.
    
    match /{collectionName}/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId}/{subCollection=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Explicitly unblock global wildcard
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}